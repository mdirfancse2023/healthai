FROM myportfolioregistry.azurecr.io/myportfolio:latest AS portfolio

FROM caddy:2.10-alpine

COPY --from=portfolio /usr/share/caddy /usr/share/caddy
COPY docker/Caddyfile.myportfolio /etc/caddy/Caddyfile

# Update route paths from /mdirfanportfolio to root / in production assets
RUN sed -i 's|path:"/mdirfanportfolio/\*"|path:"/\*"|g' /usr/share/caddy/assets/index-*.js && \
    sed -i 's|path:"/mdirfanportfolio"|path:"/"|g' /usr/share/caddy/assets/index-*.js

